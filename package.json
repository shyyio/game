{
  "name": "pipesjs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "node --import ./src/test/test-loader.js --test 'src/**/*.spec.js'",
    "schema": "rm SCHEMA.sqlite3; node --import ./src/test/test-loader.js src/test/dump-schema.js | sqlite3 SCHEMA.sqlite3",
    "save:sample": "rm -f SAMPLE.sqlite3; node --import ./src/test/test-loader.js src/test/make-sample-save.js SAMPLE.sqlite3",
    "bench:lines": "node --import ./src/test/test-loader.js src/test/production-line-benchmark.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "pixi-viewport": "^6.0.3",
    "pixi.js": "^8.19.0",
    "protobufjs": "^8.6.4",
    "underscore": "^1.13.7",
    "vue": "^3.5.18",
    "vuetify": "^3.9.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "vite": "^7.0.6",
    "vite-plugin-vuetify": "^2.1.3"
  }
}
